# PostgreSQL connection string (asyncpg driver)
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/charu_ai

# Google ADK / Vertex AI
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=global
GOOGLE_GENAI_USE_VERTEXAI=TRUE

# Gemini Live voice calls use a separate regional endpoint
GOOGLE_CLOUD_LIVE_LOCATION=us-east1

# Path to Firebase service account credentials JSON
FIREBASE_CREDENTIALS_PATH=path/to/firebase-credentials.json

# Twilio credentials for WhatsApp integration
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886
TWILIO_VOICE_NUMBER=+1234567890

# Twilio Content API template SIDs
TWILIO_CONTENT_SID_DAILY_RECAP=HXxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_CONTENT_SID_DAILY_RECAP_NO_GOAL=HXxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_CONTENT_SID_EVENING_RECAP=HXxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_CONTENT_SID_EVENING_RECAP_NO_ACCOMPLISHMENTS=HXxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_CONTENT_SID_MIDDAY_CHECKIN=HXxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_CONTENT_SID_MIDDAY_CHECKIN_V2=HXxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_CONTENT_SID_MIDDAY_CHECKIN_V3=HXxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_CONTENT_SID_WEEKLY_SUMMARY=HXxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_CONTENT_SID_MISSED_CALL_ENCOURAGEMENT=HXxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_CONTENT_SID_EMAIL_DRAFT_REVIEW=HXxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Google OAuth 2.0 client credentials
GOOGLE_OAUTH_CLIENT_ID=your-google-oauth-client-id
GOOGLE_OAUTH_CLIENT_SECRET=your-google-oauth-client-secret
GOOGLE_OAUTH_REDIRECT_URI=https://your-domain.com/auth/google/callback

# Azure OpenAI for optional semantic task deduplication
# Put real values only in .env or the deployment secret store.
TASK_EMBEDDING_DEDUP_ENABLED=false
AZURE_OPENAI_API_KEY=your-azure-openai-api-key
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_VERSION=2025-03-01-preview
AZURE_OPENAI_MODEL=gpt-5.4
AZURE_OPENAI_EMBEDDING_MODEL=text-embedding-3-large
AZURE_OPENAI_EMBEDDING_DIMENSIONS=
TASK_EMBEDDING_SIMILARITY_THRESHOLD=0.88
TASK_EMBEDDING_BACKFILL_LIMIT=25

# Secrets
OAUTH_TOKEN_ENCRYPTION_KEY=generate-a-fernet-key
STREAM_TOKEN_SECRET=generate-a-random-secret

# Base URL for Twilio webhook signature validation (proxy-safe)
WEBHOOK_BASE_URL=https://your-domain.com

# Redis URL for Celery broker, RedBeat scheduler, and ephemeral OAuth tokens
REDIS_URL=redis://localhost:6379/0

# Comma-separated allowed CORS origins
CORS_ORIGINS=http://localhost:3000
