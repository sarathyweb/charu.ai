# PostgreSQL connection string (asyncpg driver)
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/charu_ai

# Google ADK / Vertex AI
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1
GOOGLE_GENAI_USE_VERTEXAI=TRUE

# Gemini Live voice calls use a separate regional endpoint
GOOGLE_CLOUD_LIVE_LOCATION=us-east1

# Path to Firebase service account credentials JSON
FIREBASE_CREDENTIALS_PATH=path/to/firebase-credentials.json

# Twilio credentials for WhatsApp integration
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886
TWILIO_VOICE_NUMBER=+1234567890

# Google OAuth 2.0 client credentials
GOOGLE_OAUTH_CLIENT_ID=your-google-oauth-client-id
GOOGLE_OAUTH_CLIENT_SECRET=your-google-oauth-client-secret
GOOGLE_OAUTH_REDIRECT_URI=https://your-domain.com/auth/google/callback

# Secrets
OAUTH_TOKEN_ENCRYPTION_KEY=generate-a-fernet-key
STREAM_TOKEN_SECRET=generate-a-random-secret

# Base URL for Twilio webhook signature validation (proxy-safe)
WEBHOOK_BASE_URL=https://your-domain.com

# Redis URL for Celery broker, RedBeat scheduler, and ephemeral OAuth tokens
REDIS_URL=redis://localhost:6379/0

# Comma-separated allowed CORS origins
CORS_ORIGINS=http://localhost:3000
